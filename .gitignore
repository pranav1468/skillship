# File:    .gitignore
# Purpose: Files git should never track (secrets, build artefacts, editor cruft).
# Owner:   Navanish

# --- Secrets / env ---
.env
.env.local
.env.*.local
*/.env
!*/.env.example

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.egg-info/
dist/
build/

# --- Django ---
staticfiles/
media/
*.sqlite3

# --- Node / Next.js ---
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
*.tsbuildinfo

# --- IDE ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Docker ---
# keep compose files; ignore local overrides:
docker-compose.override.yml
